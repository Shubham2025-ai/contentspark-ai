# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Notes ─────────────────────────────────────────────────────
# The VITE_ prefix exposes these to the React frontend (Vite requirement)
# NEVER put your Groq API key here — users paste it directly in the UI
# NEVER commit this file with real values — add .env to .gitignore
